# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these from Firebase Console: Project Settings > General > Your apps > Web app

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com

# Google Sign-In Configuration
# Android Client ID from Google Cloud Console
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# iOS Client ID (for future iOS support)
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# Expo Client ID (for Expo Go testing)
GOOGLE_EXPO_CLIENT_ID=your_expo_client_id.apps.googleusercontent.com
